# Optional environment file for docker compose.
# Copy if you want to override defaults:
# cp compose.env.example compose.env
# docker compose --env-file compose.env up --build

POSTGRES_DB=delivery
POSTGRES_USER=delivery
POSTGRES_PASSWORD=delivery
POSTGRES_PORT=5434

BACKEND_PORT=8080
FRONTEND_PORT=5173

DEV_SEED_ENABLED=true
JWT_SECRET=delivery-development-secret-key-change-before-production-0123456789
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=14
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_BASELINE_VERSION=0
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
