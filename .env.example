# Supabase is used only as a managed PostgreSQL database.
# Do not commit a real .env file with production credentials.

DB_URL=jdbc:postgresql://db.anekdxpxqsirpipjhegn.supabase.co:5432/postgres?sslmode=require
DB_USER=postgres
DB_PASSWORD=

# Optional HikariCP tuning.
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000

# Use only when connecting to an existing database schema that was created before
# Flyway started tracking migrations. Keep false for a fresh database.
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_BASELINE_VERSION=0
