# Copy this file if you want to run Docker with an env file:
# cp docker.env.example docker.env
# docker run --rm --name delivery-backend --network host --env-file docker.env delivery-backend:local

SERVER_PORT=8080
DB_URL=jdbc:postgresql://localhost:5433/postgres
DB_USER=armando
DB_PASSWORD=1234
DEV_SEED_ENABLED=true

# Use a strong secret outside local development.
JWT_SECRET=delivery-development-secret-key-change-before-production-0123456789
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=14

DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_BASELINE_VERSION=0

JAVA_OPTS=-XX:MaxRAMPercentage=75.0
