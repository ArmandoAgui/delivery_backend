# Supabase is used only as a managed PostgreSQL database.
# Do not commit a real .env file with production credentials.

DB_URL=jdbc:postgresql://aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require
DB_USER=postgres.<project-ref>
DB_PASSWORD=<your-database-password>

# Optional HikariCP tuning.
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000

# Use only when connecting to an existing database schema that was created before
# Flyway started tracking migrations. Keep false for a fresh database.
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_BASELINE_VERSION=0

# Temporary development-only user used while authentication is disabled.
DEV_DELIVERY_USER_ID=018f0000-0000-7000-8000-000000000003

# Comma-separated frontend origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
